rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 민원 컬렉션: 누구나 읽기 가능, 쓰기 가능 (프로토타입)
    match /complaints/{document=**} {
      allow read, write: if true;
    }
    match /duplicate_links/{document=**} {
      allow read, write: if true;
    }
    match /complaint_supports/{document=**} {
      allow read, write: if true;
    }
  }
}
